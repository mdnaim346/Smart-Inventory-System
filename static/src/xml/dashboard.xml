<templates xml:space="preserve">
    <t t-name="smart_inventory.Dashboard">
        <div class="smart-dashboard-premium">
            <!-- Animated Background Elements -->
            <div class="dashboard-bg-glow"></div>
            
            <div class="dashboard-container">
                <!-- Navigation / Top Header -->
                <nav class="glass-header">
                    <div class="brand">
                        <div class="brand-logo">
                            <i class="fa fa-braille animate-spin-slow"></i>
                        </div>
                        <div class="brand-text">
                            <span class="brand-name">NEBULA <span class="text-gradient">SMART</span></span>
                            <span class="brand-tagline">Inventory Intelligence</span>
                        </div>
                    </div>
                    <div class="top-actions">
                        <div class="system-status">
                            <span class="pulse-dot"></span>
                            <span class="status-text">AI ENGINE ONLINE</span>
                        </div>
                        <button id="btn_refresh_dashboard" name="action_refresh" class="btn-neon-secondary" t-on-click="loadData">
                            <i class="fa fa-refresh"/>
                        </button>
                        <button id="btn_global_restock" name="action_restock" class="btn-neon-primary" t-on-click="triggerRestock">
                            <i class="fa fa-rocket"/> RESTOCK SHIELD
                        </button>
                    </div>
                </nav>

                <!-- Main Grid Layout -->
                <div class="dashboard-grid">
                    
                    <!-- Left Column: Metrics & Main Data -->
                    <div class="dashboard-left">
                        
                        <!-- Hero Stats Row -->
                        <section class="metrics-row">
                            <div class="metric-card glass-morph color-blue">
                                <div class="metric-icon"><i class="fa fa-cubes"/></div>
                                <div class="metric-content">
                                    <span class="metric-label">Total Inventory</span>
                                    <h2 class="metric-value" t-esc="state.totalProducts"/>
                                    <div class="metric-trend positive">+12% vs last month</div>
                                </div>
                            </div>
                            <div class="metric-card glass-morph color-red">
                                <div class="metric-icon"><i class="fa fa-warning"/></div>
                                <div class="metric-content">
                                    <span class="metric-label">Stock Risks</span>
                                    <h2 class="metric-value" t-esc="state.lowStockCount"/>
                                    <div class="metric-trend negative">Critical Threshold</div>
                                </div>
                            </div>
                            <div class="metric-card glass-morph color-orange">
                                <div class="metric-icon"><i class="fa fa-shopping-cart"/></div>
                                <div class="metric-content">
                                    <span class="metric-label">Active RFQs</span>
                                    <h2 class="metric-value" t-esc="state.pendingOrders"/>
                                    <div class="metric-trend neutral">Processing Orders</div>
                                </div>
                            </div>
                        </section>

                        <!-- Critical Stock Monitor -->
                        <section class="data-section glass-morph mt-4">
                            <div class="section-header">
                                <h3><i class="fa fa-bolt text-warning"/> Critical Stock Shortages</h3>
                                <div class="header-actions">
                                    <span class="live-indicator">LIVE MONITOR</span>
                                </div>
                            </div>
                            <div class="section-body">
                                <div class="table-container">
                                    <table class="nebula-table">
                                        <thead>
                                            <tr>
                                                <th>Product Name</th>
                                                <th>Current Stock</th>
                                                <th>Min Threshold</th>
                                                <th>Risk Factor</th>
                                                <th>Navigation</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.lowStockProducts" t-as="product" t-key="product.id">
                                                <tr class="nebula-row">
                                                    <td class="product-info">
                                                        <div class="product-avatar" t-esc="product.name ? product.name[0] : '?'"/>
                                                        <span t-esc="product.name || 'Unnamed Product'"/>
                                                    </td>
                                                    <td>
                                                        <div class="stock-progress">
                                                            <div class="progress-info">
                                                                <span class="text-danger" t-esc="product.qty_available"/> / <span t-esc="product.low_stock_threshold"/>
                                                            </div>
                                                            <div class="progress-bar-container">
                                                                <div class="progress-bar-fill bg-danger" t-attf-style="width: #{(product.qty_available / product.low_stock_threshold) * 100}%"></div>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td t-esc="product.low_stock_threshold"/>
                                                    <td>
                                                        <span class="risk-badge" t-attf-class="risk-#{product.risk_level || 'low'}" t-esc="(product.risk_level || 'low').toUpperCase()"/>
                                                    </td>
                                                    <td>
                                                        <button t-attf-id="btn_view_product_#{product.id}" t-attf-name="view_product_#{product.id}" class="btn-icon-only" t-on-click="() => this.openProduct(product.id)">
                                                            <i class="fa fa-external-link"/>
                                                        </button>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-if="state.lowStockCount === 0">
                                                <tr class="empty-row">
                                                    <td colspan="5">
                                                        <div class="empty-state-pulse">
                                                            <i class="fa fa-shield-check text-success"/>
                                                            <p>Inventory Shields at 100%. No shortages detected.</p>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </section>
                    </div>

                    <!-- Right Column: AI Insights & History -->
                    <div class="dashboard-right">
                        
                        <!-- AI Genius Panel -->
                        <section class="ai-side-panel glass-morph mb-4">
                            <div class="ai-header-premium">
                                <div class="ai-tag text-gradient">AI INSIGHT ENGINE</div>
                                <h3>Predictive Optimization</h3>
                            </div>
                            <div class="ai-body">
                                <t t-foreach="state.aiRecommendations" t-as="rec" t-key="rec.id">
                                    <div class="ai-insight-card" t-on-click="() => this.openProduct(rec.id)">
                                        <div class="insight-top">
                                            <span class="rec-title" t-esc="rec.name || 'Insight'"/>
                                            <span t-attf-class="risk-indicator risk-#{rec.risk_level || 'low'}"></span>
                                        </div>
                                        <p class="insight-summary" t-esc="rec.ai_insight"/>
                                        <div class="insight-stats">
                                            <div class="stat-item">
                                                <span class="s-label">DEMAND</span>
                                                <span class="s-value" t-esc="rec.predicted_demand"/>
                                            </div>
                                            <button t-attf-id="btn_optimize_#{rec.id}" t-attf-name="optimize_#{rec.id}" class="btn-mini-action">OPTIMIZE</button>
                                        </div>
                                    </div>
                                </t>
                                <t t-if="state.aiRecommendations.length === 0">
                                    <div class="ai-empty">
                                        <i class="fa fa-brain-circuit"/>
                                        <p>Neural networks are currently idle.</p>
                                    </div>
                                </t>
                            </div>
                        </section>

                        <!-- Restock Logs -->
                        <section class="logs-panel glass-morph">
                            <div class="section-header">
                                <h3><i class="fa fa-history"/> Auto-Log</h3>
                            </div>
                            <div class="log-stream">
                                <t t-foreach="state.recentActivities" t-as="po" t-key="po.id">
                                    <div class="log-item" t-on-click="() => this.openPurchaseOrder(po.id)">
                                        <div class="log-marker border-#{po.state}"></div>
                                        <div class="log-content">
                                            <div class="log-title"><strong t-esc="po.name"/> Initiated</div>
                                            <div class="log-sub text-muted" t-esc="po.partner_id[1]"/>
                                            <div class="log-footer">
                                                <span class="log-time" t-esc="po.date_order"/>
                                                <span t-attf-class="log-status badge-#{po.state}" t-esc="po.state.toUpperCase()"/>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                                <t t-if="state.recentActivities.length === 0">
                                    <div class="p-3 text-center text-muted italic">No recent restock events.</div>
                                </t>
                            </div>
                        </section>
                    </div>

                </div>
            </div>
        </div>
    </t>
</templates>