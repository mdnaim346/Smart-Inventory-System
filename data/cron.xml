<odoo>
    <record id="ir_cron_auto_restock" model="ir.cron">
        <field name="name">AI-Powered Auto Restock</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">model.search([('auto_restock','=',True)]).action_check_and_restock()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_generate_ai_insights" model="ir.cron">
        <field name="name">Daily AI Inventory Insights</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">model.search([]).action_generate_ai_insights()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>