<odoo>
    <record id="ir_cron_auto_restock" model="ir.cron">
        <field name="name">Auto Restock</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">
model.search([('qty_available', '&lt;', 'low_stock_threshold')]).write({'list_price': 100})
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
    </record>
</odoo>