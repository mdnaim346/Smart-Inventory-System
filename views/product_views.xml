<odoo>
    <record id="view_product_form_inherit" model="ir.ui.view">
        <field name="name">product.form.smart.inventory</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Smart Inventory" name="smart_inventory_page">
                    <group name="inventory_alerts" string="Inventory Stock Alerts">
                        <field name="low_stock_threshold" readonly="0"/>
                        <field name="is_low_stock" readonly="1"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>